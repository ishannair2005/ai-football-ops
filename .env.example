# LLM provider credentials
ANTHROPIC_API_KEY=

# Model used by all agents unless an agent overrides it
ANTHROPIC_MODEL=claude-sonnet-5

# Which club configuration to load from data/clubs/<ACTIVE_CLUB>.yaml
ACTIVE_CLUB=manchester_united

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# SportsAPIPro (sportsapipro.com) credentials for live identity/stats/transfer data.
# Leave blank to fall back to CSV/mock providers only.
SPORTSAPIPRO_API_KEY=
